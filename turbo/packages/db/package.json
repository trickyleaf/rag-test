{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./seed": "./src/seed.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "drizzle-orm": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "latest",
    "dotenv": "^17.4.2",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
