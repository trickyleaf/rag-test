# App
APP_DEFAULT_LOCALE=en
APP_ENABLE_MOCK_AUTH=true

# AI Gateway (Vercel)
# Required for chat and embeddings.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-4o-mini
AI_EMBEDDING_MODEL=openai/text-embedding-3-small

# LlamaParse / LlamaIndex Cloud
# Required for real document parsing during ingestion.
LLAMA_CLOUD_API_KEY=

# Qdrant (cloud or self-hosted)
# Required for vector indexing and retrieval.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Vercel Blob
# Required for document file storage.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Database (Neon PostgreSQL)
# Optional in v1: in-memory demo data is used when not set.
DATABASE_URL=
