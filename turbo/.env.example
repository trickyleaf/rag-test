# App
APP_DEFAULT_LOCALE=en
APP_ENABLE_MOCK_AUTH=true

# Database
# Required when replacing the in-memory/demo data with Neon/PostgreSQL.
DATABASE_URL=

# Vercel AI Gateway
# Optional for local UI/demo. Required for real model responses in /api/chat.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-mini

# LlamaParse / LlamaIndex Cloud
# Required for real document parsing.
LLAMA_CLOUD_API_KEY=

# Qdrant
# Required for real vector indexing/retrieval.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Vercel Blob
# Required for real document upload/storage.
BLOB_READ_WRITE_TOKEN=
